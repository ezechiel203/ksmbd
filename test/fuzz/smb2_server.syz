# 17. SMB2 LOGOFF (MS-SMB2 §2.2.7)
# ─────────────────────────────────────────────────────────────────────────────

sendmsg$smb2_logoff(fd smb2_sock, msg ptr[in, smb2_logoff_msg], flags const[0, int32])

smb2_logoff_msg {
    nb      smb2_nb_generic
    hdr     smb2_hdr_logoff
    body    smb2_logoff_req_body
}

smb2_hdr_logoff {
    ProtocolId      const[0xFE534D42, int32]
    StructureSize   const[64, int16]
    CreditCharge    const[1, int16]
    Status          const[0, int32]
    Command         const[0x0002, int16]    # LOGOFF
    CreditRequest   int16[1:10]
    Flags           const[0, int32]
    NextCommand     const[0, int32]
    MessageId       smb2_message_id
    ProcessId       const[0, int32]
    TreeId          const[0, int32]
    SessionId       smb2_session_id
    Signature       array[const[0, int8], 16]
}

smb2_logoff_req_body {
    StructureSize   const[4, int16]
    Reserved        const[0, int16]
}

# ─────────────────────────────────────────────────────────────────────────────
# 18. SMB2 TREE_DISCONNECT (MS-SMB2 §2.2.11)
# ─────────────────────────────────────────────────────────────────────────────

sendmsg$smb2_tree_disconnect(fd smb2_sock,
    msg ptr[in, smb2_tree_disconnect_msg], flags const[0, int32])

smb2_tree_disconnect_msg {
    nb      smb2_nb_generic
    hdr     smb2_hdr_tree_disc
    body    smb2_tree_disc_req_body
}

smb2_hdr_tree_disc {
    ProtocolId      const[0xFE534D42, int32]
    StructureSize   const[64, int16]
    CreditCharge    const[1, int16]
    Status          const[0, int32]
    Command         const[0x0004, int16]    # TREE_DISCONNECT
    CreditRequest   int16[1:10]
    Flags           const[0, int32]
    NextCommand     const[0, int32]
    MessageId       smb2_message_id
    ProcessId       const[0, int32]
    TreeId          smb2_tree_id
    SessionId       smb2_session_id
    Signature       array[const[0, int8], 16]
}

smb2_tree_disc_req_body {
    StructureSize   const[4, int16]
    Reserved        const[0, int16]
}

# ─────────────────────────────────────────────────────────────────────────────
# 19. SMB2 OPLOCK_BREAK acknowledgment (MS-SMB2 §2.2.24.1 / §2.2.24.2)
#
#     Client sends this in response to a server oplock break notification.
#     StructureSize=24 for oplock break, StructureSize=36 for lease break.
# ─────────────────────────────────────────────────────────────────────────────

sendmsg$smb2_oplock_break_ack(fd smb2_sock,
    msg ptr[in, smb2_oplock_break_msg], flags const[0, int32])

smb2_oplock_break_msg [
    oplock  smb2_oplock_break_oplock
    lease   smb2_oplock_break_lease
]

smb2_oplock_break_oplock {
    nb              smb2_nb_generic
    hdr             smb2_hdr_oplock
    StructureSize   const[24, int16]
    OplockLevel     flags[smb2_oplock_break_level, int8]
    Reserved        const[0, int8]
    Reserved2       const[0, int32]
    PersistentFileId smb2_persistent_file_id
    VolatileFileId  smb2_volatile_file_id
}

smb2_oplock_break_lease {
    nb              smb2_nb_generic
    hdr             smb2_hdr_oplock
    StructureSize   const[36, int16]
    Reserved        const[0, int16]
    Reserved2       const[0, int32]
    LeaseKey        array[int8, 16]
    CurrentLeaseState flags[smb2_lease_state, int32]
    NewLeaseState   flags[smb2_lease_state, int32]
    BreakReason     const[0, int32]
    AccessMaskHint  const[0, int32]
    ShareMaskHint   const[0, int32]
}

smb2_hdr_oplock {
    ProtocolId      const[0xFE534D42, int32]
    StructureSize   const[64, int16]
    CreditCharge    const[1, int16]
    Status          const[0, int32]
    Command         const[0x0012, int16]    # OPLOCK_BREAK
    CreditRequest   int16[1:10]
    Flags           const[0, int32]
    NextCommand     const[0, int32]
    MessageId       smb2_message_id
    ProcessId       const[0, int32]
    TreeId          const[0, int32]
    SessionId       smb2_session_id
    Signature       array[const[0, int8], 16]
}

smb2_oplock_break_level = 0x00, 0x01    # NONE or LEVEL_II

# ─────────────────────────────────────────────────────────────────────────────
# 20. SMB3 Transform Header (encrypted message wrapper, MS-SMB2 §2.2.41)
#
#     Wraps any SMB2 PDU for encrypted transport when the session uses
#     SMB3 encryption (AES-CCM or AES-GCM).
# ─────────────────────────────────────────────────────────────────────────────

sendmsg$smb2_transform(fd smb2_sock,
    msg ptr[in, smb2_transform_msg], flags const[0, int32])

smb2_transform_msg {
    nb          smb2_nb_generic
    hdr         smb2_transform_hdr_body
    encrypted   smb2_encrypted_payload
}

smb2_transform_hdr_body {
    ProtocolId              const[0xFD534D42, int32]  # 0xFD 'S' 'M' 'B'
    Signature               array[int8, 16]
    Nonce                   array[int8, 16]
    OriginalMessageSize     int32[64:65536]
    Reserved1               const[0, int16]
    Flags                   const[0x0001, int16]    # SMB2_TRANSFORM_FLAG_ENCRYPTED
    SessionId               smb2_session_id
}

smb2_encrypted_payload {
    ciphertext  array[int8, 64:65536]
}

# ─────────────────────────────────────────────────────────────────────────────
# 20b. SMB2 Compression Transform Header (MS-SMB2 §2.2.42)
#
#      Wraps a compressed SMB2 PDU.  ProtocolId = 0xFC534D42.
# ─────────────────────────────────────────────────────────────────────────────

sendmsg$smb2_compress(fd smb2_sock,
    msg ptr[in, smb2_compress_msg], flags const[0, int32])

smb2_compress_msg {
    nb      smb2_nb_generic
    hdr     smb2_compress_hdr_body
    payload array[int8, 0:65536]
}

smb2_compress_hdr_body {
    ProtocolId                      const[0xFC534D42, int32]  # 0xFC 'S' 'M' 'B'
    OriginalCompressedSegmentSize   int32[64:65536]
    CompressionAlgorithm            flags[smb2_compress_alg_value, int16]
    Flags                           flags[smb2_compress_hdr_flags, int16]
    Offset                          int32
}

smb2_compress_hdr_flags = 0x0000, 0x0001  # none / chained

# ─────────────────────────────────────────────────────────────────────────────
# Compound request: NEGOTIATE → SESSION_SETUP in a single TCP segment
#
#   The NextCommand field of the first PDU's header points to the byte offset
#   of the second PDU within the compound message.  Both PDUs are preceded by
#   a single NetBIOS header covering the total length.
# ─────────────────────────────────────────────────────────────────────────────

sendmsg$smb2_compound_neg_sess(fd smb2_sock,
    msg ptr[in, smb2_compound_neg_sess_msg], flags const[0, int32])

smb2_compound_neg_sess_msg {
    nb          smb2_nb_generic
    neg_hdr     smb2_hdr_negotiate_compound
    neg_body    smb2_negotiate_req_body
    sess_hdr    smb2_hdr_session_compound
    sess_body   smb2_sess_setup_req_body
    sess_spnego smb2_ntlmssp_neg_blob
}

smb2_hdr_negotiate_compound {
    ProtocolId      const[0xFE534D42, int32]
    StructureSize   const[64, int16]
    CreditCharge    const[0, int16]
    Status          const[0, int32]
    Command         const[0x0000, int16]
    CreditRequest   int16[1:10]
    Flags           const[0, int32]
    NextCommand     int32[0:65536]          # offset to next compound PDU
    MessageId       const[0, int64]
    ProcessId       const[0, int32]
    TreeId          const[0, int32]
    SessionId       const[0, int64]
    Signature       array[const[0, int8], 16]
}

smb2_hdr_session_compound {
    ProtocolId      const[0xFE534D42, int32]
    StructureSize   const[64, int16]
    CreditCharge    const[1, int16]
    Status          const[0, int32]
    Command         const[0x0001, int16]
    CreditRequest   int16[1:32]
    Flags           const[0x00000004, int32]    # SMB2_FLAGS_RELATED_OPERATIONS
    NextCommand     const[0, int32]
    MessageId       smb2_message_id
    ProcessId       const[0, int32]
    TreeId          const[0xFFFFFFFF, int32]    # placeholder (related compound)
    SessionId       const[0xFFFFFFFFFFFFFFFF, int64]  # placeholder
    Signature       array[const[0, int8], 16]
}

# ─────────────────────────────────────────────────────────────────────────────
# SMB2 FLUSH (MS-SMB2 §2.2.17) — trivial but tests access checks
# ─────────────────────────────────────────────────────────────────────────────

sendmsg$smb2_flush(fd smb2_sock, msg ptr[in, smb2_flush_msg], flags const[0, int32])

smb2_flush_msg {
    nb      smb2_nb_generic
    hdr     smb2_hdr_flush
    body    smb2_flush_req_body
}

smb2_hdr_flush {
    ProtocolId      const[0xFE534D42, int32]
    StructureSize   const[64, int16]
    CreditCharge    const[1, int16]
    Status          int32
    Command         const[0x0007, int16]    # FLUSH
    CreditRequest   int16[1:10]
    Flags           flags[smb2_hdr_flags, int32]
    NextCommand     int32
    MessageId       smb2_message_id
    ProcessId       int32
    TreeId          smb2_tree_id
    SessionId       smb2_session_id
    Signature       array[const[0, int8], 16]
}

smb2_flush_req_body {
    StructureSize       const[24, int16]
    Reserved1           const[0, int16]
    Reserved2           const[0, int32]
    PersistentFileId    smb2_persistent_file_id
    VolatileFileId      smb2_volatile_file_id
}

# ─────────────────────────────────────────────────────────────────────────────
# recvmsg: receive server responses (needed by syzkaller to track state)
# ─────────────────────────────────────────────────────────────────────────────

recvmsg$smb2(fd smb2_sock, msg ptr[out, recv_msg], flags const[0, int32])

recv_msg {
    hdr     ptr[out, array[int8, 68]]    # NetBIOS(4) + SMB2_HDR(64)
    iov_len len[hdr, intptr]
    control const[0, intptr]
    ctllen  const[0, intptr]
    msgflags const[0, int32]
}

# ─────────────────────────────────────────────────────────────────────────────
# close: tear down the TCP connection
# ─────────────────────────────────────────────────────────────────────────────

close$smb2(fd smb2_sock)
