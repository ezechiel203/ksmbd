# ─────────────────────────────────────────────────────────────────────────────
# 9. SMB2 LOCK (MS-SMB2 §2.2.26)
#
#    Lock elements exercise byte-range locking.
# ─────────────────────────────────────────────────────────────────────────────

sendmsg$smb2_lock(fd smb2_sock, msg ptr[in, smb2_lock_msg], flags const[0, int32])

smb2_lock_msg {
    nb          smb2_nb_generic
    hdr         smb2_hdr_lock
    body        smb2_lock_req_body
    lock_elems  smb2_lock_element_array
}

smb2_hdr_lock {
    ProtocolId      const[0xFE534D42, int32]
    StructureSize   const[64, int16]
    CreditCharge    const[1, int16]
    Status          int32
    Command         const[0x000A, int16]    # LOCK
    CreditRequest   int16[1:32]
    Flags           flags[smb2_hdr_flags, int32]
    NextCommand     int32
    MessageId       smb2_message_id
    ProcessId       int32
    TreeId          smb2_tree_id
    SessionId       smb2_session_id
    Signature       array[const[0, int8], 16]
}

smb2_lock_req_body {
    StructureSize       const[48, int16]
    LockCount           int16[1:64]
    LockSequenceNumber  int32[0:0xFFFFFFFF]     # bits 0-3 = index, 4-7 = sequence
    PersistentFileId    smb2_persistent_file_id
    VolatileFileId      smb2_volatile_file_id
}

smb2_lock_element_array [
    one     array[smb2_lock_element, 1]
    two     array[smb2_lock_element, 2]
    eight   array[smb2_lock_element, 8]
    many    array[smb2_lock_element, 1:64]
]

smb2_lock_element {
    Offset      smb2_lock_offset
    Length      smb2_lock_length
    Flags       flags[smb2_lock_flags, int32]
    Reserved    const[0, int32]
}

smb2_lock_offset [
    zero        const[0, int64]
    small       int64[0:4096]
    large       int64[0:0xFFFFFFFF]
    max_minus   const[0xFFFFFFFFFFFFFF00, int64]
    max         const[0xFFFFFFFFFFFFFFFF, int64]
]

smb2_lock_length [
    zero    const[0, int64]
    one     const[1, int64]
    small   int64[1:4096]
    large   int64[1:0xFFFFFFFF]
    max     const[0xFFFFFFFFFFFFFFFF, int64]
]

smb2_lock_flags = 0x00000001, 0x00000002, 0x00000004, 0x00000010,
                  0x00000011, 0x00000012

# ─────────────────────────────────────────────────────────────────────────────
# 10. SMB2 IOCTL (MS-SMB2 §2.2.31)
#
#     Covers several important FSCTLs: VALIDATE_NEGOTIATE_INFO,
#     PIPE_TRANSCEIVE, COPYCHUNK, QUERY_NETWORK_INTERFACE_INFO, etc.
# ─────────────────────────────────────────────────────────────────────────────

sendmsg$smb2_ioctl(fd smb2_sock, msg ptr[in, smb2_ioctl_msg], flags const[0, int32])

smb2_ioctl_msg {
    nb      smb2_nb_generic
    hdr     smb2_hdr_ioctl
    body    smb2_ioctl_req_body
    inbuf   smb2_ioctl_input
}

smb2_hdr_ioctl {
    ProtocolId      const[0xFE534D42, int32]
    StructureSize   const[64, int16]
    CreditCharge    int16[1:8]
    Status          int32
    Command         const[0x000B, int16]    # IOCTL
    CreditRequest   int16[1:64]
    Flags           flags[smb2_hdr_flags, int32]
    NextCommand     int32
    MessageId       smb2_message_id
    ProcessId       int32
    TreeId          smb2_tree_id
    SessionId       smb2_session_id
    Signature       array[const[0, int8], 16]
}

smb2_ioctl_req_body {
    StructureSize           const[57, int16]
    Reserved                const[0, int16]
    CtlCode                 flags[smb2_ioctl_ctlcode, int32]
    PersistentFileId        smb2_persistent_file_id
    VolatileFileId          smb2_volatile_file_id
    InputOffset             int32
    InputCount              bytesize[smb2_ioctl_input, int32]
    MaxInputResponse        int32
    OutputOffset            const[0, int32]
    OutputCount             const[0, int32]
    MaxOutputResponse       int32[0:65536]
    Flags                   const[0x00000001, int32]    # SMB2_0_IOCTL_IS_FSCTL
    Reserved2               const[0, int32]
}

# Key FSCTL codes used by ksmbd
smb2_ioctl_ctlcode = 0x00140204,   # FSCTL_VALIDATE_NEGOTIATE_INFO
                     0x0011C017,   # FSCTL_PIPE_TRANSCEIVE
                     0x0011400C,   # FSCTL_PIPE_PEEK
                     0x00110018,   # FSCTL_PIPE_WAIT
                     0x001401D4,   # FSCTL_LMR_REQUEST_RESILIENCY
                     0x001440F2,   # FSCTL_COPYCHUNK
                     0x001480F2,   # FSCTL_COPYCHUNK_WRITE
                     0x001400FC,   # FSCTL_QUERY_NETWORK_INTERFACE_INFO
                     0x00144064,   # FSCTL_SRV_ENUMERATE_SNAPSHOTS
                     0x00090000,   # FSCTL_REQUEST_OPLOCK_LEVEL_1
                     0x00090004,   # FSCTL_REQUEST_OPLOCK_LEVEL_2
                     0x00090008,   # FSCTL_REQUEST_BATCH_OPLOCK
                     0x000900C4,   # FSCTL_SET_SPARSE
                     0x000980C8,   # FSCTL_SET_ZERO_DATA
                     0x000940CF,   # FSCTL_QUERY_ALLOCATED_RANGES
                     0x000900A4,   # FSCTL_SET_REPARSE_POINT
                     0x000900A8,   # FSCTL_GET_REPARSE_POINT
                     0x00090098,   # FSCTL_SET_OBJECT_ID
                     0x0009009C,   # FSCTL_GET_OBJECT_ID
                     0x00098344,   # FSCTL_DUPLICATE_EXTENTS_TO_FILE
                     0x00140078,   # FSCTL_REQUEST_RESUME_KEY
                     0x00060194,   # FSCTL_DFS_GET_REFERRALS
                     0x0009C040,   # FSCTL_SET_COMPRESSION
                     0x0009003C,   # FSCTL_GET_COMPRESSION
                     0x0009027C,   # FSCTL_GET_INTEGRITY_INFORMATION
                     0x009013C0    # FSCTL_QUERY_ON_DISK_VOLUME_INFO

smb2_ioctl_input [
    validate_neg    smb2_ioctl_validate_neg
    copychunk       smb2_ioctl_copychunk
    resiliency      smb2_ioctl_resiliency
    pipe_write      array[int8, 0:512]
    random          array[int8, 0:4096]
]

# FSCTL_VALIDATE_NEGOTIATE_INFO input (MS-SMB2 §2.2.31.4)
smb2_ioctl_validate_neg {
    Capabilities    flags[smb2_global_cap_flags, int32]
    ClientGuid      array[int8, 16]
    SecurityMode    flags[smb2_security_mode_flags, int16]
    DialectCount    int16[1:6]
    Dialects        array[smb2_dialect_value, 1:6]
}

# FSCTL_COPYCHUNK / FSCTL_COPYCHUNK_WRITE (MS-SMB2 §2.2.31.1)
smb2_ioctl_copychunk {
    SourceKey       array[int8, 24]
    ChunkCount      int32[0:256]
    Reserved        const[0, int32]
    Chunks          array[smb2_copychunk_element, 1:16]
}

smb2_copychunk_element {
    SourceOffset    int64
    TargetOffset    int64
    Length          int32[0:1048576]
    Reserved        const[0, int32]
}

# FSCTL_LMR_REQUEST_RESILIENCY (MS-SMB2 §2.2.31.3)
smb2_ioctl_resiliency {
    Timeout     int32[0:300000]
    Reserved    const[0, int32]
}

