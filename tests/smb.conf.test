#
# Test configuration for ksmbd integration tests
# This file is used by run_integration.sh to set up a test environment.
#

[global]
	workgroup = TESTGROUP
	server string = ksmbd test server
	netbios name = KSMBDTEST

[test_share]
	path = /tmp/ksmbd_test_share
	read only = no
	browseable = yes
	guest ok = yes
	force user = nobody
